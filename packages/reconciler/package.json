{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/reconciler",
  "version": "1.4.0",
  "private": false,
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/reconciler"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": true,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tsup",
    "dev": "pnpm tsup --watch",
    "lint": "pnpm ultracite check",
    "test": "pnpm vitest --dir=src"
  },
  "dependencies": {
    "@deckgl-fiber-renderer/shared": "workspace:*",
    "@deckgl-fiber-renderer/types": "workspace:*",
    "react-reconciler": "~0.31.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.31.0",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "@deck.gl/mesh-layers": "^9.1.0",
    "react": "^19",
    "react-dom": "^19"
  }
}
