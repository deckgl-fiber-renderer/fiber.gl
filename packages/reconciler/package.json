{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/reconciler",
  "version": "2.0.0",
  "private": false,
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/reconciler"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config.js",
    "./extend": "./dist/extend.js",
    "./renderer": "./dist/renderer.js",
    "./side-effects": "./dist/side-effects.js",
    "./types": "./dist/types.js",
    "./utils": "./dist/utils.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm exec tsdown",
    "dev": "pnpm exec tsdown --watch",
    "format": "pnpm exec ultracite fix",
    "lint": "pnpm exec ultracite check",
    "test": "pnpm exec vitest --dir=src"
  },
  "dependencies": {
    "@deckgl-fiber-renderer/shared": "workspace:*",
    "@deckgl-fiber-renderer/types": "workspace:*",
    "react-reconciler": "catalog:"
  },
  "devDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "@deck.gl/test-utils": "^9.2.11",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
