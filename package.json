{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "pnpm exec turbo build --filter=./packages/*",
    "dev": "pnpm exec turbo dev --filter=./packages/*",
    "lint": "pnpm exec turbo lint --filter=./packages/*",
    "test": "pnpm exec turbo test --filter=./packages/*",
    "format": "pnpm exec turbo format --filter=./packages/*",
    "deps:mismatch-fix": "pnpm exec syncpack fix-mismatches",
    "changeset": "pnpm exec changeset",
    "changeset:release": "pnpm run build && pnpm exec changeset publish",
    "changeset:version": "pnpm exec changeset version",
    "prepare": "pnpm exec lefthook install"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.30.0",
    "@fission-ai/openspec": "^1.3.0",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "syncpack": "^14.3.0",
    "turbo": "^2.9.6",
    "ultracite": "7.5.8"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
