{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/dom",
  "version": "1.4.0",
  "private": false,
  "description": "A React renderer for Deck.gl",
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/dom"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components": "./dist/components.js",
    "./hooks": "./dist/hooks.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tsdown",
    "dev": "pnpm tsdown --watch",
    "format": "pnpm dlx ultracite fix",
    "lint": "pnpm dlx ultracite check",
    "test": "pnpm vitest --dir=src"
  },
  "dependencies": {
    "@deckgl-fiber-renderer/reconciler": "workspace:*",
    "@deckgl-fiber-renderer/shared": "workspace:*",
    "@deckgl-fiber-renderer/types": "workspace:*",
    "client-only": "^0.0.1",
    "its-fine": "^2.0.0",
    "use-isomorphic-layout-effect": "^1.2.1"
  },
  "devDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
