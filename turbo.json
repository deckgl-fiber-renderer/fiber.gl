{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": {},

    "format": {},

    "dev": {
      "persistent": true,
      "cache": false
    },

    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    }
  }
}
