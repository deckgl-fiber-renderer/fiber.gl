{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/shared",
  "version": "2.0.0",
  "private": false,
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/shared"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./constants": "./dist/constants.js",
    "./log": "./dist/log.js",
    "./store": "./dist/store.js",
    "./utils": "./dist/utils.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm exec tsdown",
    "dev": "pnpm exec tsdown --watch",
    "format": "pnpm exec ultracite fix",
    "lint": "pnpm exec ultracite check",
    "test": "pnpm exec vitest --dir=src"
  },
  "dependencies": {
    "loglayer": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/mapbox": "catalog:"
  }
}
