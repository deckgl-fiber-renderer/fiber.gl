{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/shared",
  "version": "1.4.0",
  "private": false,
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/shared"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tsdown",
    "dev": "pnpm tsdown --watch",
    "lint": "pnpm ultracite check",
    "test": "pnpm vitest --dir=src"
  },
  "dependencies": {
    "loglayer": "^6.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0"
  }
}
