{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/types",
  "version": "1.4.0",
  "private": false,
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/types"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": true,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tsc",
    "dev": "pnpm tsc --watch",
    "lint": "pnpm ultracite check",
    "test": "pnpm vitest --dir=src"
  },
  "devDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@deck.gl/core": "catalog:",
    "@deck.gl/geo-layers": "catalog:",
    "@deck.gl/layers": "catalog:",
    "@deck.gl/mapbox": "catalog:",
    "@deck.gl/mesh-layers": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:"
  }
}
