{
  "$schema": "https://json.schemastore.org/package",
  "name": "@deckgl-fiber-renderer/dom",
  "version": "1.4.0",
  "private": false,
  "description": "A React renderer for Deck.gl",
  "keywords": [
    "deck.gl",
    "deckgl",
    "fiber",
    "react",
    "renderer"
  ],
  "bugs": {
    "url": "https://github.com/deckgl-fiber-renderer/fiber.gl/issues"
  },
  "license": "MIT",
  "author": "Brandon Pierce (https://github.com/brandonjpierce)",
  "maintainers": [
    "Brandon Pierce (https://github.com/brandonjpierce)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deckgl-fiber-renderer/fiber.gl.git",
    "directory": "packages/dom"
  },
  "files": [
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components": "./dist/components.js",
    "./hooks": "./dist/hooks.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm tsdown",
    "dev": "pnpm tsdown --watch",
    "lint": "pnpm biome lint",
    "test": "pnpm vitest --dir=src"
  },
  "dependencies": {
    "@deckgl-fiber-renderer/reconciler": "workspace:*",
    "@deckgl-fiber-renderer/shared": "workspace:*",
    "@deckgl-fiber-renderer/types": "workspace:*",
    "client-only": "^0.0.1",
    "its-fine": "^2.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "^29.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "inlinedDependencies": {
    "@deck.gl/core": "9.2.11",
    "@deck.gl/mapbox": "9.2.11",
    "@loaders.gl/loader-utils": "4.3.4",
    "@luma.gl/core": "9.2.6",
    "@luma.gl/engine": "9.2.6",
    "@luma.gl/shadertools": "9.2.6",
    "@math.gl/core": "4.1.0",
    "@math.gl/types": "4.1.0",
    "@probe.gl/log": "4.1.1",
    "@probe.gl/stats": "4.1.1",
    "mjolnir.js": "3.0.0"
  }
}
